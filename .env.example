# Firebase public web config (safe to commit, protected by Firestore rules + App Check)
PUBLIC_FIREBASE_API_KEY=your-api-key
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project
PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
