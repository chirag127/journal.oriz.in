{
	"name": "journal",
	"type": "module",
	"version": "0.1.0",
	"private": true,
	"engines": {
		"node": ">=22.12.0"
	},
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"dev": "astro dev",
		"start": "astro dev",
		"icons": "node scripts/build-icons.mjs",
		"prebuild": "node scripts/build-icons.mjs",
		"build": "astro check && astro build",
		"build:fast": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"check": "astro check",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"deploy": "firebase deploy",
		"deploy:hosting": "firebase deploy --only hosting",
		"deploy:rules": "firebase deploy --only firestore:rules,firestore:indexes"
	},
	"dependencies": {
		"@astrojs/check": "0.9.4",
		"@astrojs/mdx": "4.3.6",
		"@astrojs/react": "4.4.0",
		"@astrojs/rss": "4.0.18",
		"@astrojs/sitemap": "3.6.0",
		"@hookform/resolvers": "5.4.0",
		"@tailwindcss/vite": "4.3.0",
		"@types/dompurify": "3.2.0",
		"@types/react": "19.2.16",
		"@types/react-dom": "19.2.3",
		"@vite-pwa/astro": "1.2.0",
		"@vitejs/plugin-react": "5.1.1",
		"astro": "5.18.2",
		"dayjs": "1.11.21",
		"dompurify": "3.4.7",
		"firebase": "12.14.0",
		"fuse.js": "7.4.1",
		"jszip": "3.10.1",
		"lucide-react": "1.17.0",
		"marked": "18.0.4",
		"nanoid": "5.1.11",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"react-hook-form": "7.77.0",
		"recharts": "3.8.1",
		"tailwindcss": "4.3.0",
		"workbox-window": "7.4.1",
		"zod": "4.4.3",
		"zustand": "5.0.14"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"@playwright/test": "1.60.0",
		"@tailwindcss/typography": "^0.5.19",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@testing-library/user-event": "14.6.1",
		"@vitest/ui": "4.1.8",
		"happy-dom": "20.9.0",
		"sharp": "^0.34.5",
		"vitest": "4.1.8"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@firebase/util",
			"esbuild",
			"protobufjs",
			"sharp"
		]
	}
}
