---
/*
 * LegalPage — shared shell for the legal/* routes.
 *
 * v2: dusk surface, GT Sectra heading, iA Writer Quattro body. No card,
 * no sidebar, no eyebrow gradient. The colophon footer carries the version.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'

interface Props {
  title: string
  description?: string
  heading: string
  updated?: string
  crumbLabel: string
}

const { title, description, heading, updated, crumbLabel } = Astro.props
---

<BaseLayout title={title} description={description}>
  <section class="spine prose-page">
    <p class="eyebrow chrome">
      <a href="/">oriz-journal</a> / <a href="/legal/">legal</a> / {crumbLabel}
    </p>
    <h1>{heading}</h1>
    {updated && <p class="updated chrome">last updated · {updated}</p>}

    <article class="prose">
      <slot />
    </article>
  </section>
</BaseLayout>

<style>
  .prose-page {
    padding-block: 3rem 4rem;
    font-family: var(--font-body);
  }
  .eyebrow {
    color: var(--graphite);
    font-family: var(--font-sans);
    font-size: 12px;
    letter-spacing: 0.04em;
    margin: 0 0 0.75rem;
  }
  .eyebrow a { color: var(--graphite); text-decoration: none; }
  .eyebrow a:hover { color: var(--seal-red); }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .updated {
    margin: 0 0 2rem;
    color: var(--graphite);
    font-family: var(--font-sans);
    font-size: 12px;
  }
  .prose {
    font-family: var(--font-body);
    line-height: 1.7;
    color: var(--page-cream);
  }
  @media (prefers-color-scheme: light) {
    .prose { color: var(--ink, #1a1a22); }
  }
</style>

<style is:global>
  .prose h2 {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
    color: var(--page-cream);
  }
  @media (prefers-color-scheme: light) {
    .prose h2 { color: var(--ink, #1a1a22); }
  }
  .prose p { margin: 0 0 1rem; max-width: 66ch; }
  .prose ul { padding-left: 1.5rem; margin: 0 0 1rem; max-width: 66ch; }
  .prose li { margin-bottom: 0.5rem; }
  .prose a {
    color: inherit;
    text-decoration-color: var(--seal-red);
  }
  .prose a:hover { color: var(--seal-red); }
  .prose code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    color: var(--graphite);
  }
  .prose .card {
    margin: 1.5rem 0;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--rule);
  }
  .prose .card p { margin: 0.375rem 0; }
</style>
