---
/*
 * BaseLayout — v2.
 *
 * Per-app chrome: local Header (date picker + tags + drawer), local Wordmark.
 * Sidebar/Footer/BottomBar come from @chirag127/astro-chrome as structure;
 * AppSidebarContent fills the sidebar slot with journal-specific links
 * (by-tag / by-date / by-mood / Settings). BottomBar takes per-app icons
 * (Home / Today / Tags / Search / Menu) from src/data/bottombar-actions.ts.
 *
 * THE SEAL — React island top-right. Defaults to 'sealed'; editor + read
 * dispatch `seal:set` events to transition.
 */
import '~/styles/global.css'
import '~/styles/oriz-ui-overrides.css'
import '@chirag127/astro-shell/tokens.css'
import Header from '~/components/Header.astro'
import Sidebar from '@chirag127/astro-chrome/Sidebar.astro'
import Footer from '@chirag127/astro-chrome/Footer.astro'
import BottomBar from '@chirag127/astro-chrome/BottomBar.astro'
import AppSidebarContent from '~/components/AppSidebarContent.astro'
import Seal from '~/components/Seal'
import { SITE_CONFIG } from '~/lib/siteConfig'
import { bottomBarActions } from '~/data/bottombar-actions'

interface Props {
  title?: string
  description?: string
  canonical?: string
  noindex?: boolean
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
  hideHeader?: boolean
  hideFooter?: boolean
  initialSealState?: 'typing' | 'sealing' | 'sealed' | 'closing'
}

const {
  title = `${SITE_CONFIG.name} — ${SITE_CONFIG.tagline}`,
  description = SITE_CONFIG.description,
  canonical = `${SITE_CONFIG.origin}${Astro.url.pathname}`,
  noindex = false,
  jsonLd,
  hideHeader = false,
  hideFooter = false,
  initialSealState = 'sealed',
} = Astro.props

const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT
const beaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN
const ga4Id = import.meta.env.PUBLIC_GA4_ID
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0B0B10" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#F5EFE0" media="(prefers-color-scheme: light)" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={`${SITE_CONFIG.name} — oriz`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@chirag127" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600;8..60,700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/iaolo/iA-Fonts@master/iA%20Writer%20Quattro/Variable/Webfonts/iAWriterQuattroV.css"
    />

    {jsonLd && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd])}
      />
    )}

    {adsenseClient && (
      <script
        is:inline
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
        crossorigin="anonymous"
      />
    )}

    {beaconToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${beaconToken}"}`}
      />
    )}

    {ga4Id && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`} />
        <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)};gtag('js',new Date());gtag('config','${ga4Id}');`} />
      </>
    )}
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    {!hideHeader && <Header />}
    <Sidebar><AppSidebarContent /></Sidebar>
    <main id="main"><slot /></main>
    {!hideFooter && <Footer />}
    <BottomBar actions={bottomBarActions} />
    <Seal client:idle initialState={initialSealState} />
  </body>
</html>
