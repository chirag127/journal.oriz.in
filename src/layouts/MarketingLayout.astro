---
import { ThemeToggle } from "@components/react/ui/ThemeToggle";
import { APP_NAME, APP_TAGLINE } from "@/lib/constants";
import BaseLayout from "./BaseLayout.astro";

interface Props {
	title?: string;
	description?: string;
	showHeader?: boolean;
}

const { title, description = APP_TAGLINE, showHeader = true } = Astro.props;
---

<BaseLayout title={title} description={description}>
	<div class="bg-grain min-h-screen">
		{
			showHeader && (
				<header class="sticky top-0 z-40 border-b border-border/60 bg-bg/80 backdrop-blur-md">
					<div class="container-wide flex h-14 items-center justify-between gap-4 px-4 sm:px-6 lg:px-10">
						<a href="/" class="flex items-baseline gap-2 no-underline">
							<span class="font-display text-xl font-medium tracking-tight">{APP_NAME}</span>
							<span class="hidden font-mono text-[10px] uppercase tracking-[0.18em] text-fg-muted sm:inline">
								·  {APP_TAGLINE}
							</span>
						</a>
					<div class="flex items-center gap-2 sm:gap-3">
						<ThemeToggle client:only="react" />
						<a
							href="/login"
							class="hidden text-sm text-fg-muted hover:text-fg sm:inline no-underline"
						>
							Sign in
						</a>
						<a
							href="/signup"
							class="inline-flex h-11 items-center rounded-md bg-ink px-3.5 text-sm font-medium text-paper no-underline hover:bg-ink-soft sm:h-9"
						>
							Start writing
						</a>
					</div>
					</div>
				</header>
			)
		}
		<main class="relative z-10">
			<slot />
		</main>
		<footer class="relative z-10 mt-16 border-t border-border/60 py-10 sm:mt-24">
			<div class="container-wide flex flex-col items-center justify-between gap-4 px-4 pb-safe text-center text-xs text-fg-muted sm:flex-row sm:px-6 sm:text-left lg:px-10">
				<p>
					© {new Date().getFullYear()} {APP_NAME}. Your words belong to you.
				</p>
				<div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2">
					<a href="/manifesto" class="no-underline hover:text-fg">Manifesto</a>
					<a href="/changelog" class="no-underline hover:text-fg">Changelog</a>
					<a href="https://oriz.in" class="no-underline hover:text-fg" target="_blank" rel="noopener">
						oriz.in
					</a>
				</div>
			</div>
		</footer>
	</div>
</BaseLayout>
