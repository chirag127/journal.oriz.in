---
/*
 * AppPage — wraps BaseLayout for signed-in app surfaces.
 *
 * v2 simplification: there is NO sidebar (the chrome header's drawer is the
 * only nav), NO heading + lede slabs (each route owns its own typography),
 * NO breadcrumb. The Astro page mounts one React island; this layout just
 * sets `noindex` and provides the dusk frame + footer.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'

interface Props {
  title: string
  description?: string
  noindex?: boolean
  hideHeader?: boolean
  hideFooter?: boolean
  initialSealState?: 'typing' | 'sealing' | 'sealed' | 'closing'
}

const {
  title,
  description,
  noindex = true,
  hideHeader = false,
  hideFooter = false,
  initialSealState = 'sealed',
} = Astro.props
---

<BaseLayout
  title={title}
  description={description}
  noindex={noindex}
  hideHeader={hideHeader}
  hideFooter={hideFooter}
  initialSealState={initialSealState}
>
  <div class="app-page spine">
    <slot />
  </div>

  <style>
    .app-page {
      padding-block: 2.5rem 1rem;
    }
  </style>
</BaseLayout>
