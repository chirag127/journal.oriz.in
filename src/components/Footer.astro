---
/*
 * Footer — slim colophon line for non-editor pages.
 *
 * Per the v2 brief: there is NO global app-shell footer. Dashboard ends with
 * `[ all entries → ]` and whitespace. Editor footer = word count + lock
 * status only (rendered by the editor itself, not this file). Settings /
 * about / export / legal pages carry one line in Inter 12px graphite,
 * centered, 64px from page bottom.
 */
const version = import.meta.env.PUBLIC_GIT_SHA?.slice(0, 7) ?? '0.x.x'
---

<footer class="colophon">
  <p>oriz-journal · open source · sealed with libsodium · v{version}</p>
</footer>

<style>
  .colophon {
    margin-top: 4rem;
    padding: 4rem 1rem 4rem;
    text-align: center;
  }
  .colophon p {
    margin: 0;
    color: var(--graphite);
    font-family: var(--font-sans);
    font-size: 12px;
    letter-spacing: 0.04em;
  }
</style>
