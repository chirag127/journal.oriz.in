---
/*
 * oriz-journal — landing / marketing index.
 *
 * Per the v2 brief: this is a quiet sales surface, NOT the dashboard. The
 * dashboard lives at /dashboard (auth-gated). This page is what someone
 * sees if they hit `journal.oriz.in` cold — a single column, a few
 * sentences in display serif, and one CTA: "open the journal →".
 *
 * NO type-grid (the v1 ten emoji cards are deleted). NO feature grid. NO
 * "what you get" cards. NO install prompt button (the PWA installs itself
 * when the app shell loads). The seal is the hero.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'
import { SITE_CONFIG } from '~/lib/siteConfig'

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_CONFIG.name,
  url: SITE_CONFIG.origin,
  description: SITE_CONFIG.description,
  publisher: { '@type': 'Person', name: 'Chirag Singhal' },
}
---

<BaseLayout jsonLd={jsonLd}>
  <section class="spine landing">
    <h1 class="landing-h">A quiet place for the thoughts worth keeping.</h1>

    <p class="landing-lede">
      A privacy-first PWA journal. Tiptap editor, libsodium-sealed entries,
      offline-first, ten kinds of journal. Plaintext never leaves the device.
    </p>

    <hr class="hairline" />

    <p class="landing-cta">
      <a href="/dashboard" class="landing-cta-primary">open the journal &rarr;</a>
    </p>

    <hr class="hairline" />

    <dl class="landing-defs">
      <div>
        <dt>The seal</dt>
        <dd>
          A small mark in the corner of every page. Solid when the entry is
          encrypted to disk, hollow while you&rsquo;re typing, and pulses while
          libsodium seals the bytes. It is the only thing that moves.
        </dd>
      </div>
      <div>
        <dt>Cream on dusk</dt>
        <dd>
          Entries live on a cream page floating on an ink-black frame. iA
          Writer Quattro for the body, GT Sectra for the date, Inter for the
          chrome. 66 characters per line. The room is quiet on purpose.
        </dd>
      </div>
      <div>
        <dt>What is not here</dt>
        <dd>
          No streak counters, no flame icons, no <em>don&rsquo;t break the chain</em>
          nags. No AI in the writing surface. No padlock icon — the seal is
          the privacy signal. No emoji.
        </dd>
      </div>
      <div>
        <dt>Yours</dt>
        <dd>
          Free. Open source. Anonymous trial, no email needed. Sign in later
          to sync across devices via the shared oriz account, which works on
          every <code>*.oriz.in</code> site.
        </dd>
      </div>
    </dl>

    <p class="landing-meta chrome">
      <a href="/account/">sign in</a> · <a href="/about">about</a> ·
      <a href="/legal/privacy/">privacy</a> ·
      <a href={`https://github.com/chirag127/oriz-journal`}>source</a>
    </p>
  </section>
</BaseLayout>

<style>
  .landing {
    padding-block: clamp(3rem, 8vw, 6rem) clamp(2rem, 6vw, 4rem);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .landing-h {
    font-family: var(--font-display);
    font-size: clamp(1.875rem, 5vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.1;
    margin: 0;
    max-width: 22ch;
    color: var(--page-cream);
  }
  @media (prefers-color-scheme: light) {
    .landing-h { color: var(--ink, #1a1a22); }
  }
  .landing-lede {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--graphite);
    max-width: 56ch;
    margin: 0;
  }
  .landing-cta {
    margin: 0.5rem 0;
    font-family: var(--font-body);
    font-size: 1.0625rem;
  }
  .landing-cta-primary {
    color: var(--seal-red);
    text-decoration: none;
    border-bottom: 1px solid var(--seal-red);
    padding-bottom: 1px;
  }
  .landing-cta-primary:hover {
    background: color-mix(in oklab, var(--seal-red) 12%, transparent);
  }
  .landing-defs {
    margin: 1rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    font-family: var(--font-body);
  }
  .landing-defs > div {
    display: grid;
    grid-template-columns: 8rem minmax(0, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 600px) {
    .landing-defs > div { grid-template-columns: 1fr; gap: 0.25rem; }
  }
  .landing-defs dt {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--page-cream);
  }
  @media (prefers-color-scheme: light) {
    .landing-defs dt { color: var(--ink, #1a1a22); }
  }
  .landing-defs dd {
    margin: 0;
    color: var(--graphite);
    font-size: 1rem;
    line-height: 1.65;
  }
  .landing-defs dd em { color: var(--page-cream); font-style: italic; }
  @media (prefers-color-scheme: light) {
    .landing-defs dd em { color: var(--ink, #1a1a22); }
  }
  .landing-defs dd code {
    background: rgb(255 255 255 / 0.05);
    padding: 0.125em 0.375em;
    font-family: var(--font-mono);
    font-size: 0.875em;
    color: var(--graphite);
  }
  @media (prefers-color-scheme: light) {
    .landing-defs dd code { background: rgb(0 0 0 / 0.05); }
  }
  .landing-meta {
    margin: 2rem 0 0;
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--graphite);
  }
  .landing-meta a {
    color: var(--graphite);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--rule);
  }
  .landing-meta a:hover { color: var(--seal-red); text-decoration-color: var(--seal-red); }
</style>
