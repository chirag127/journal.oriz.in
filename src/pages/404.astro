---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Not found" noindex>
	<div class="bg-grain grid min-h-screen place-items-center px-6">
		<div class="max-w-md text-center">
			<p class="font-mono text-[10px] uppercase tracking-[0.18em] text-fg-muted">404</p>
			<h1 class="mt-2 font-display text-5xl">Page not found</h1>
			<p class="mt-2 text-fg-muted">The page you're looking for doesn't exist.</p>
			<a href="/" class="mt-6 inline-flex text-sm text-accent">← Back to home</a>
		</div>
	</div>
</BaseLayout>
