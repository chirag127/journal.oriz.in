---
import FinishSignIn from '~/components/FinishSignIn'
import BaseLayout from '~/layouts/BaseLayout.astro'
import { SITE_CONFIG } from '~/lib/siteConfig'
---

<BaseLayout
  title={`finishing sign-in — ${SITE_CONFIG.name}`}
  description="Completing email-link sign-in."
  noindex={true}
>
  <section class="spine finish">
    <FinishSignIn client:load />
  </section>
</BaseLayout>

<style>
  .finish { padding-block: 5rem 4rem; text-align: center; }
</style>
