---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="offline — oriz-journal" description="You are offline." noindex={true}>
  <section class="spine offline">
    <h1>You are offline.</h1>
    <p>
      Your last visited pages are still available below. New entries you write
      while offline will sync once you are back online.
    </p>
    <div class="off-actions">
      <a href="/dashboard" class="link">open dashboard</a>
      <span aria-hidden="true">·</span>
      <a href="/entries" class="link">recent entries</a>
      <span aria-hidden="true">·</span>
      <button type="button" id="off-retry" class="link">try again</button>
    </div>
  </section>
  <script is:inline>
    document.getElementById('off-retry')?.addEventListener('click', () => location.reload())
  </script>
  <style>
    .offline {
      padding-block: clamp(3rem, 8vw, 6rem) clamp(2rem, 6vw, 4rem);
      max-width: 56ch;
      font-family: var(--font-body);
    }
    h1 {
      font-family: var(--font-display);
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 600;
      margin: 0 0 1rem;
    }
    p { color: var(--graphite); line-height: 1.7; margin: 0 0 2rem; }
    .off-actions {
      display: flex;
      gap: 0.625rem;
      align-items: center;
      flex-wrap: wrap;
      font-family: var(--font-sans);
      font-size: 13px;
      color: var(--graphite);
    }
    .link {
      background: transparent;
      border: 0;
      padding: 0;
      font: inherit;
      color: var(--graphite);
      text-decoration: underline;
      text-underline-offset: 3px;
      cursor: pointer;
    }
    .link:hover { color: var(--seal-red); }
  </style>
</BaseLayout>
