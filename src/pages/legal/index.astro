---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { SITE_CONFIG } from '~/lib/siteConfig'

const sections = [
  {
    slug: 'privacy',
    label: 'Privacy policy',
    desc: "What we collect, what we don't, your rights.",
  },
  { slug: 'terms', label: 'Terms of use', desc: 'The rules for using journal.oriz.in.' },
  { slug: 'disclaimer', label: 'Disclaimer', desc: 'Not financial / medical / legal advice.' },
  { slug: 'cookies', label: 'Cookie policy', desc: 'What cookies and localStorage we set.' },
  { slug: 'grievance', label: 'Grievance officer', desc: 'Mandatory contact under IT Rules 2021.' },
]
---

<BaseLayout
  title={`legal — ${SITE_CONFIG.name}`}
  description={`Privacy, terms, and grievance contact for ${SITE_CONFIG.origin}.`}
>
  <section class="spine prose-page">
    <p class="eyebrow chrome"><a href="/">oriz-journal</a> / legal</p>
    <h1>Legal</h1>

    <ul class="legal-list">
      {sections.map((s) => (
        <li>
          <a href={`/legal/${s.slug}/`} class="row">
            <span class="row-label">{s.label}</span>
            <span class="row-desc">{s.desc}</span>
            <span class="row-arrow" aria-hidden="true">&rarr;</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .prose-page { padding-block: 3rem 4rem; font-family: var(--font-body); }
  .eyebrow {
    color: var(--graphite);
    font-family: var(--font-sans);
    font-size: 12px;
    margin: 0 0 0.75rem;
  }
  .eyebrow a { color: var(--graphite); text-decoration: none; }
  .eyebrow a:hover { color: var(--seal-red); }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 600;
    margin: 0 0 1.5rem;
  }
  .legal-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  .row {
    display: grid;
    grid-template-columns: 12rem minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: baseline;
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--rule);
    color: inherit;
    text-decoration: none;
  }
  .row:hover .row-label { color: var(--seal-red); }
  .row:hover .row-arrow { color: var(--seal-red); }
  .row-label {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--page-cream);
  }
  @media (prefers-color-scheme: light) {
    .row-label { color: var(--ink, #1a1a22); }
  }
  .row-desc {
    color: var(--graphite);
    font-family: var(--font-body);
    font-size: 14px;
  }
  .row-arrow {
    color: var(--graphite);
    font-family: var(--font-sans);
  }
  @media (max-width: 600px) {
    .row { grid-template-columns: minmax(0, 1fr) auto; }
    .row-desc { grid-column: 1 / -1; }
  }
</style>
