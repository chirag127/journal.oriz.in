---
import LegalPage from '~/layouts/LegalPage.astro'
import { FAMILY } from '~/lib/family'
import { SITE_CONFIG } from '~/lib/siteConfig'

const updated = FAMILY.legalUpdated
---

<LegalPage
  title={`disclaimer — ${SITE_CONFIG.name}`}
  description={`What ${SITE_CONFIG.name} is and isn't.`}
  heading="Disclaimer"
  updated={updated}
  crumbLabel="disclaimer"
>
  <p>
    Everything on {SITE_CONFIG.origin} is published in good faith for general
    use only. Use it at your own risk.
  </p>

  <h2>Not therapy or medical advice</h2>
  <p>
    Journaling can be a helpful reflection practice, but {SITE_CONFIG.name}
    is not a mental-health service. If you are in distress, please reach out
    to a qualified professional or a local helpline.
  </p>

  <h2>Not financial / legal advice</h2>
  <p>
    Anything you record in your journal — about money, taxes, contracts, or
    personal matters — stays a personal note. It is not advice from {FAMILY.brand}.
    Consult qualified professionals before acting on any of it.
  </p>

  <h2>Service availability</h2>
  <p>
    {SITE_CONFIG.name} is provided on a best-effort basis on the Firebase
    Spark plan. We do our best to keep your entries safe, but you should
    export your data periodically — the Export tool produces a clean
    JSON / Markdown / ZIP archive.
  </p>

  <h2>External links</h2>
  <p>
    We link to third-party sites we find useful. We don&rsquo;t control their
    content, and inclusion is not an endorsement.
  </p>
</LegalPage>
