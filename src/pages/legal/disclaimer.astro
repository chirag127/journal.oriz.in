---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { FAMILY } from '@chirag127/oriz-ui'
import { SITE_CONFIG } from '~/lib/siteConfig'

const updated = FAMILY.legalUpdated
---

<BaseLayout
  title={`Disclaimer — ${SITE_CONFIG.name}`}
  description={`What ${SITE_CONFIG.name} is and isn't.`}
  showSidebar={false}
>
  <header class="container-prose page-head">
    <p class="eyebrow"><a href="/">{SITE_CONFIG.name}</a> / <a href="/legal/">Legal</a> / Disclaimer</p>
    <h1>Disclaimer</h1>
    <p class="meta">Last updated: {updated}</p>
  </header>

  <article class="container-prose prose">
    <p>
      Everything on {SITE_CONFIG.origin} is published in good faith for general
      use only. Use it at your own risk.
    </p>

    <h2>Not therapy or medical advice</h2>
    <p>
      Journaling can be a helpful reflection practice, but {SITE_CONFIG.name}
      is not a mental-health service. If you are in distress, please reach out
      to a qualified professional or a local helpline.
    </p>

    <h2>Not financial / legal advice</h2>
    <p>
      Anything you record in your journal — about money, taxes, contracts, or
      personal matters — stays a personal note. It is not advice from {FAMILY.brand}.
      Consult qualified professionals before acting on any of it.
    </p>

    <h2>Service availability</h2>
    <p>
      {SITE_CONFIG.name} is provided on a best-effort basis on the Firebase
      Spark plan. We do our best to keep your entries safe, but you should
      export your data periodically — the Export tool produces a clean JSON / Markdown / ZIP archive.
    </p>

    <h2>External links</h2>
    <p>
      We link to third-party sites we find useful. We don't control their
      content, and inclusion is not an endorsement.
    </p>
  </article>
</BaseLayout>

<style>
  .page-head { padding-block: 3rem 1.5rem; border-bottom: 1px solid var(--color-border); }
  .eyebrow { color: var(--color-fg-muted); font-size: 0.8125rem; margin: 0 0 0.5rem; }
  .eyebrow a { color: var(--color-fg-muted); text-decoration: none; }
  h1 { font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 600; letter-spacing: -0.02em; margin: 0; }
  .meta { color: var(--color-fg-soft); font-size: 0.875rem; margin: 0.5rem 0 0; }
  .prose { padding-block: 2.5rem 4rem; color: var(--color-prose); line-height: 1.7; font-size: 1.0625rem; }
  .prose h2 { font-family: var(--font-serif); font-size: 1.375rem; font-weight: 600; color: var(--color-fg); margin: 2rem 0 1rem; }
  .prose p { margin: 0 0 1.25rem; }
  .prose a { color: var(--color-accent); }
</style>
