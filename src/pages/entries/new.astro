---
import { AppRoute } from "@components/react/ui/AppRoute";
import BaseLayout from "@/layouts/BaseLayout.astro";

const date = Astro.url.searchParams.get("date") ?? undefined;
const template = Astro.url.searchParams.get("template") ?? undefined;
---

<BaseLayout title="New entry" noindex>
	<AppRoute client:only="react" initialDate={date} initialTemplate={template} />
</BaseLayout>
