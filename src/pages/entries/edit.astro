---
import { EditEntryPage } from '~/components/AppPages'
/*
 * Edit-view shell. Firebase Hosting rewrites /entries/{id}/edit to /entries/edit.
 *
 * Same treatment as `new`: full-bleed editor, header hidden, the editor
 * surface controls the chrome fade and the seal.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout
  title="edit — oriz-journal"
  noindex={true}
  hideHeader={true}
  hideFooter={true}
  initialSealState="sealed"
>
  <EditEntryPage client:only="react" />
</BaseLayout>
