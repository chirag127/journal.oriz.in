---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { FAMILY } from '@chirag127/oriz-ui'
import { SITE_CONFIG } from '~/lib/siteConfig'
---

<BaseLayout
  title={`About — ${SITE_CONFIG.name}`}
  description={`About ${SITE_CONFIG.name} — a privacy-first PWA journal in the oriz family.`}
  showSidebar={false}
>
  <header class="container-prose page-head">
    <p class="eyebrow"><a href="/">{SITE_CONFIG.name}</a> / About</p>
    <h1>About Journal</h1>
  </header>

  <article class="container-prose prose">
    <p class="lede">
      Journal is a privacy-first journal in the <a href={FAMILY.rootOrigin}>oriz family</a> —
      ten journal types, offline-first, fully on the Firebase Spark plan.
    </p>

    <h2>What this site does</h2>
    <p>
      Capture today, revisit a year, notice who you’re becoming. Journal supports
      daily, gratitude, learning, reading, travel, work, fitness, dream, research,
      and reflection journals — plus any custom type you need. Moods, tags,
      favorites, pinned entries, calendar, timeline, memories, stats, goals,
      templates. Markdown editor with live preview, autosave, and full export
      to JSON / Markdown / ZIP.
    </p>

    <h2>Privacy by default</h2>
    <p>
      Your entries live in Firestore under your own user ID. Nobody else can
      read them — Firestore rules enforce this server-side. Account deletion
      removes every Firestore document owned by your <code>uid</code>. No
      tracking across sessions, no selling of data, no required signup.
    </p>

    <h2>Part of oriz</h2>
    <p>
      Journal is one site in the <a href={FAMILY.rootOrigin}>oriz family</a> —
      a free collection of static sites covering books, cards, finance, dev
      tools, blog, and journaling. Single sign-in via
      <code>{FAMILY.authDomain}</code> works across every site.
    </p>

    <h2>Open source</h2>
    <p>
      Source: <a href={`https://github.com/${FAMILY.operator.githubHandle}/oriz-journal`}>github.com/{FAMILY.operator.githubHandle}/oriz-journal</a>.
      Issues, PRs, and ideas welcome.
    </p>
  </article>
</BaseLayout>

<style>
  .page-head { padding-block: 3rem 1.5rem; border-bottom: 1px solid var(--color-border); }
  .eyebrow { color: var(--color-fg-muted); font-size: 0.8125rem; margin: 0 0 0.5rem; }
  .eyebrow a { color: var(--color-fg-muted); text-decoration: none; }
  h1 { font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 600; letter-spacing: -0.02em; margin: 0; }
  .prose { padding-block: 2.5rem 4rem; color: var(--color-prose); line-height: 1.75; font-size: 1.0625rem; }
  .prose .lede { font-size: 1.1875rem; color: var(--color-fg); margin: 0 0 2rem; }
  .prose h2 { font-family: var(--font-serif); font-size: 1.5rem; font-weight: 600; color: var(--color-fg); margin: 2.5rem 0 1rem; }
  .prose p { margin: 0 0 1.25rem; }
  .prose a { color: var(--color-accent); }
  .prose code { background: var(--color-bg-muted); padding: 0.125em 0.375em; border-radius: 0.25rem; font-size: 0.875em; }
</style>
