---
import { AuthForm } from "@components/react/auth/AuthForm";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Sign in" description="Welcome back to your journal.">
	<div class="bg-grain min-h-screen">
		<div class="container-wide flex min-h-screen flex-col px-4 sm:px-6 lg:px-10">
			<header class="flex h-16 items-center justify-between">
				<a href="/" class="font-display text-xl font-medium tracking-tight no-underline">Journal</a>
				<a href="/signup" class="text-sm text-fg-muted no-underline hover:text-fg">Create account</a>
			</header>
			<div class="grid flex-1 place-items-center py-12">
				<div class="w-full max-w-md">
					<p
						class="font-mono text-[10px] uppercase tracking-[0.18em] text-fg-muted animate-reveal"
					>
						Welcome back
					</p>
					<h1
						class="mt-3 font-display text-4xl leading-[1.1] tracking-tight animate-reveal"
						style="animation-delay: 60ms"
					>
						Sign in
					</h1>
					<p
						class="mt-2 text-fg-muted animate-reveal"
						style="animation-delay: 120ms"
					>
						Continue your story.
					</p>
					<div class="mt-8 animate-reveal" style="animation-delay: 180ms">
						<AuthForm client:only="react" mode="signin" />
					</div>
				</div>
			</div>
		</div>
	</div>
</BaseLayout>
