---
import AccountPanel from '~/components/AccountPanel'
import BaseLayout from '~/layouts/BaseLayout.astro'
import { SITE_CONFIG } from '~/lib/siteConfig'
---

<BaseLayout
  title={`account — ${SITE_CONFIG.name}`}
  description="Sign in to oriz-journal. One account works across every oriz site."
  noindex={true}
>
  <section class="spine prose-page">
    <p class="eyebrow chrome"><a href="/">oriz-journal</a> / account</p>
    <h1>Account</h1>
    <p class="lede">
      One sign-in works across every oriz site. Your journal entries stay
      tied to your account and follow you anywhere.
    </p>

    <AccountPanel client:load siteName="oriz-journal" />
  </section>
</BaseLayout>

<style>
  .prose-page { padding-block: 3rem 4rem; font-family: var(--font-body); }
  .eyebrow {
    color: var(--graphite);
    font-family: var(--font-sans);
    font-size: 12px;
    margin: 0 0 0.75rem;
  }
  .eyebrow a { color: var(--graphite); text-decoration: none; }
  .eyebrow a:hover { color: var(--seal-red); }
  h1 { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 2.5rem); font-weight: 600; margin: 0 0 1rem; }
  .lede {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.125rem;
    color: var(--graphite);
    max-width: 50ch;
    margin: 0 0 1rem;
  }
</style>
