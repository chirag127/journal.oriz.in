---
import { ContactForm } from '@chirag127/oriz-ui'
import BaseLayout from '~/layouts/BaseLayout.astro'
import { FAMILY } from '~/lib/family'
import { SITE_CONFIG } from '~/lib/siteConfig'

const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? ''
---

<BaseLayout
  title={`contact — ${SITE_CONFIG.name}`}
  description={`Get in touch about ${SITE_CONFIG.name}.`}
>
  <section class="spine prose-page">
    <p class="eyebrow chrome"><a href="/">oriz-journal</a> / contact</p>
    <h1>Contact</h1>

    <p class="lede">
      Fastest route is email:
      <a href={`mailto:${FAMILY.operator.email}`}><strong>{FAMILY.operator.email}</strong></a>.
    </p>
    <p>
      For anything journal-related — bug, suggestion, lost-account help —
      use the form below. It posts to Web3Forms which forwards to my inbox.
      No data is stored on this site.
    </p>

    <ContactForm client:load web3formsKey={web3formsKey} />

    <p class="meta chrome">
      For privacy questions or DMCA notices, see the
      <a href="/legal/grievance/">grievance officer</a> page (mandatory under IT Rules 2021).
    </p>
  </section>
</BaseLayout>

<style>
  .prose-page {
    padding-block: 3rem 4rem;
    font-family: var(--font-body);
    line-height: 1.7;
  }
  .eyebrow {
    color: var(--graphite);
    font-family: var(--font-sans);
    font-size: 12px;
    letter-spacing: 0.04em;
    margin: 0 0 0.75rem;
  }
  .eyebrow a { color: var(--graphite); text-decoration: none; }
  .eyebrow a:hover { color: var(--seal-red); }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 600;
    margin: 0 0 1.5rem;
  }
  .lede {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.125rem;
    color: var(--graphite);
    max-width: 50ch;
    margin: 0 0 1rem;
  }
  p { margin: 0 0 1rem; max-width: 66ch; }
  a { color: inherit; text-decoration-color: var(--seal-red); }
  a:hover { color: var(--seal-red); }
  .meta { font-size: 13px; margin-top: 2rem; }
</style>
