---
import BaseLayout from "@/layouts/BaseLayout.astro";
const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? "";
---

<BaseLayout title="Contact" description="Get in touch about Journal.">
	<header class="container-prose page-head">
		<p class="eyebrow"><a href="/">Journal</a> / Contact</p>
		<h1>Contact</h1>
	</header>

	<section class="container-prose prose">
		<p class="lede">
			Found a bug, broken export, or have a feature idea for Journal? The
			fastest way to reach me is email:
			<a href="mailto:whyiswhen@gmail.com"><strong>whyiswhen@gmail.com</strong></a>.
		</p>
		<p>
			Or use the form below — it posts to Web3Forms which forwards to my
			inbox. No data is stored on this site.
		</p>

		<form action="https://api.web3forms.com/submit" method="POST" class="contact-form">
			<input type="hidden" name="access_key" value={web3formsKey} />
			<input type="hidden" name="from_name" value="journal.oriz.in contact form" />
			<input type="text" name="botcheck" class="hp" tabindex="-1" autocomplete="off" />

			<label class="field">
				<span>Your name</span>
				<input type="text" name="name" required autocomplete="name" />
			</label>
			<label class="field">
				<span>Email</span>
				<input type="email" name="email" required autocomplete="email" />
			</label>
			<label class="field">
				<span>Subject</span>
				<input type="text" name="subject" required />
			</label>
			<label class="field">
				<span>Message</span>
				<textarea name="message" rows="6" required></textarea>
			</label>

			<button type="submit" class="btn-primary">Send</button>
		</form>

		<p class="meta">
			For privacy questions or DMCA notices, see the
			<a href="/legal/grievance/">grievance officer</a> page (mandatory under IT Rules 2021).
		</p>
	</section>
</BaseLayout>

<style>
	.page-head {
		padding-block: 3rem 1.5rem;
		border-bottom: 1px solid var(--color-border, #d9d0bd);
	}
	.eyebrow {
		color: var(--color-ink-muted, #6b6256);
		font-size: 0.8125rem;
		margin: 0 0 0.5rem;
	}
	.eyebrow a { color: var(--color-ink-muted, #6b6256); text-decoration: none; }
	h1 {
		font-family: var(--font-display, "Fraunces", serif);
		font-size: clamp(2rem, 4vw, 2.75rem);
		font-weight: 600;
		letter-spacing: -0.02em;
		margin: 0;
	}
	.prose {
		padding-block: 2.5rem 4rem;
		line-height: 1.7;
		font-size: 1.0625rem;
	}
	.prose .lede { font-size: 1.1875rem; margin: 0 0 1.5rem; }
	.prose a { color: var(--color-sienna, #b45309); }
	.contact-form { display: flex; flex-direction: column; gap: 1rem; margin-block: 2rem; }
	.field { display: flex; flex-direction: column; gap: 0.375rem; }
	.field span {
		font-size: 0.875rem;
		color: var(--color-ink-muted, #6b6256);
		font-weight: 500;
	}
	.field input,
	.field textarea {
		padding: 0.625rem 0.875rem;
		background: var(--color-paper-soft, #f1ece2);
		border: 1px solid var(--color-rule, #d9d0bd);
		border-radius: 0.375rem;
		font-family: inherit;
		font-size: 1rem;
	}
	.field input:focus,
	.field textarea:focus {
		outline: none;
		border-color: var(--color-sienna, #b45309);
	}
	.field textarea { resize: vertical; min-height: 120px; }
	.hp { position: absolute; left: -9999px; opacity: 0; }
	.btn-primary {
		align-self: flex-start;
		height: 44px;
		padding-inline: 1.5rem;
		background: var(--color-sienna, #b45309);
		color: #fff;
		border: 0;
		border-radius: 0.375rem;
		font-family: inherit;
		font-size: 1rem;
		font-weight: 500;
		cursor: pointer;
	}
	.meta {
		font-size: 0.875rem;
		color: var(--color-ink-muted, #6b6256);
		margin-top: 2rem;
	}
	.container-prose {
		max-width: 720px;
		margin-inline: auto;
		padding-inline: clamp(1rem, 4vw, 2rem);
	}
</style>
